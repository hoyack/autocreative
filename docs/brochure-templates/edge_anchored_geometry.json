        {
          "type": "image_placeholder",
          "bbox": [140, 220, 700, 500],
          "slot": "spot_1",
          "mask": "rounded",
          "corner_radius": 22,
          "fallback_fill": {
            "type": "linear_gradient",
            "angle": 18,
            "stops": [
              { "offset": 0.0, "color": "#DCE9E1" },
              { "offset": 1.0, "color": "#FFFFFF" }
            ]
