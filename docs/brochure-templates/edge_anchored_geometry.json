          "content_key": "sections[1].heading",
          "font_size": 52,
          "line_height": 58,
          "weight": "bold",
          "color": "#14261F"
        },
        {
          "type": "bullets",
          "bbox": [140, 450, 640, 520],
          "content_key": "sections[1].bullets",
          "max_items": 5,
          "bullet_style": "dash",
          "bullet_color": "#1F7A5C",
          "text_color": "#14261F",
          "font_size": 28,
          "line_height": 38
        }
      ]
    },
    "inner_right": {
      "description": "Top band and top-left wedge create a strong entry edge for the last panel.",
      "background": {
        "type": "solid",
        "color": "#F7F5EE"
      },
      "elements": [
        {
          "type": "shape",
          "kind": "rect",
          "rect": [0, 0, 1100, 100],
          "fill": { "type": "solid", "color": "#1F7A5C" },
          "bleed": "top",
          "z": 1
        },
        {
          "type": "shape",
          "kind": "triangle",
          "points": [[0, 0], [320, 0], [0, 320]],
          "fill": { "type": "solid", "color": "#C9A14A" },
