{
  "schema_version": "1",
  "name": "edge_anchored_geometry",
  "description": "Template defined by wedges, bands, and corner geometry anchored hard to panel edges so content reads inward from the frame.",
  "tone_keywords": ["framed", "architectural", "confident", "grounded", "premium"],
  "canvas": {
    "width": 1100,
    "height": 2550
  },
  "palette": {
    "accent_default": "#1F7A5C",
    "neutral_dark": "#14261F",
    "neutral_light": "#F7F5EE",
    "muted": "#D8D4C8",
    "extras": {
      "moss_soft": "#DCE9E1",
      "gold_note": "#C9A14A"
    }
  },
  "typography": {
    "heading_family": "'Sora', 'Inter', sans-serif",
    "body_family": "'Inter', 'Helvetica Neue', sans-serif",
    "cover_title_size": 104,
    "cover_subtitle_size": 36,
    "heading_size": 52,
    "body_size": 30,
    "body_line_height": 42,
    "body_max_chars_per_line": 29,
    "bullet_size": 28,
    "bullet_line_height": 38
  },
  "panels": {
    "front_cover": {
      "description": "Centered hero framed by a corner wedge and left anchor band.",
      "background": {
        "type": "solid",
        "color": "#F7F5EE"
      },
      "elements": [
        {
          "type": "shape",
          "kind": "rect",
          "rect": [0, 0, 120, 2550],
          "fill": { "type": "solid", "color": "#1F7A5C" },
          "bleed": "left",
          "z": 1
        },
        {
          "type": "shape",
          "kind": "triangle",
          "points": [[1100, 0], [780, 0], [1100, 320]],
          "fill": { "type": "solid", "color": "#C9A14A", "opacity": 1.0 },
          "bleed": "top",
          "z": 2
        },
        {
          "type": "image_placeholder",
          "bbox": [170, 200, 700, 980],
          "slot": "hero",
          "mask": "rounded",
          "corner_radius": 26,
          "fallback_fill": {
            "type": "linear_gradient",
            "angle": 20,
            "stops": [
              { "offset": 0.0, "color": "#DCE9E1" },
              { "offset": 1.0, "color": "#FFFFFF" }
            ]
          },
          "z": 3
        },
        {
          "type": "text",
          "bbox": [170, 1260, 680, 220],
          "role": "cover_title",
          "content_key": "title",
          "font_size": 104,
          "line_height": 92,
          "weight": "bold",
          "color": "#14261F"
        },
        {
          "type": "text",
          "bbox": [170, 1500, 660, 120],
          "role": "cover_subtitle",
          "content_key": "subtitle",
          "font_size": 36,
          "line_height": 44,
          "color": "#14261F"
        }
      ]
    },
    "back_cover": {
      "description": "Back panel framed by edge bands and a top-right wedge.",
      "background": {
        "type": "solid",
        "color": "#F7F5EE"
      },
      "elements": [
        {
          "type": "shape",
          "kind": "rect",
          "rect": [0, 0, 1100, 120],
          "fill": { "type": "solid", "color": "#1F7A5C" },
          "bleed": "top",
