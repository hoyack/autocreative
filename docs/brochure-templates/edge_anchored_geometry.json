        "type": "solid",
        "color": "#F7F5EE"
      },
      "elements": [
        {
          "type": "shape",
          "kind": "rect",
          "rect": [0, 0, 80, 2550],
          "fill": { "type": "solid", "color": "#DCE9E1" },
          "bleed": "left",
          "z": 1
        },
        {
          "type": "shape",
          "kind": "rect",
          "rect": [1020, 0, 80, 2550],
          "fill": { "type": "solid", "color": "#1F7A5C", "opacity": 0.25 },
          "bleed": "right",
          "z": 1
        },
        {
          "type": "text",
          "bbox": [140, 220, 640, 150],
