{
  "schema_version": "1",
  "name": "layered_depth_stack",
  "description": "Multi-layer brochure template using stacked translucent cards, offset surfaces, and overlapping content planes.",
  "tone_keywords": ["layered", "luxury", "immersive", "premium", "depth"],
  "canvas": {
    "width": 1100,
    "height": 2550
  },
  "palette": {
    "accent_default": "#C96C2D",
    "neutral_dark": "#1F2933",
    "neutral_light": "#FBF7F1",
    "muted": "#E6DCCF",
    "extras": {
      "warm_shadow": "#D6B79A",
      "sage": "#8AA391"
    }
  },
  "typography": {
    "heading_family": "'Manrope', 'Inter', sans-serif",
    "body_family": "'Inter', 'Helvetica Neue', sans-serif",
    "cover_title_size": 108,
    "cover_subtitle_size": 36,
    "heading_size": 52,
    "body_size": 34,
    "body_line_height": 44,
    "body_max_chars_per_line": 29,
    "bullet_size": 32,
    "bullet_line_height": 42
  },
  "panels": {
    "front_cover": {
      "description": "Hero image sits in a stacked set of translucent rounded cards.",
      "background": {
        "type": "linear_gradient",
        "angle": 180,
        "stops": [
          { "offset": 0.0, "color": "#FBF7F1" },
          { "offset": 1.0, "color": "#F1E7DA" }
        ]
      },
      "elements": [
        {
          "type": "shape",
          "kind": "rounded_rect",
          "rect": [190, 180, 700, 980],
          "path_params": { "corner_radius": 42 },
          "fill": { "type": "solid", "color": "#D6B79A", "opacity": 0.45 },
          "z": 1
        },
        {
          "type": "shape",
          "kind": "rounded_rect",
          "rect": [140, 130, 700, 980],
          "path_params": { "corner_radius": 42 },
          "fill": { "type": "solid", "color": "#FFFFFF", "opacity": 0.72 },
          "z": 2
        },
        {
          "type": "image_placeholder",
          "show_placeholder_label": false,
          "bbox": [170, 160, 700, 980],
          "slot": "hero",
          "mask": "rounded",
          "corner_radius": 42,
          "fallback_fill": {
            "type": "linear_gradient",
            "angle": 35,
            "stops": [
              { "offset": 0.0, "color": "#E6DCCF" },
              { "offset": 1.0, "color": "#FBF7F1" }
            ]
          },
          "z": 3
        },
        {
          "type": "shape",
          "kind": "rounded_rect",
          "rect": [330, 990, 580, 560],
          "path_params": { "corner_radius": 30 },
          "fill": { "type": "solid", "color": "#FFFFFF", "opacity": 0.9 },
          "z": 4
        },
        {
          "type": "text",
          "bbox": [380, 1080, 470, 220],
          "role": "cover_title",
          "content_key": "title",
          "font_size": 108,
          "line_height": 94,
          "weight": "bold",
          "color": "#1F2933"
        },
        {
          "type": "text",
          "bbox": [380, 1320, 450, 140],
          "role": "cover_subtitle",
          "content_key": "subtitle",
          "font_size": 36,
          "line_height": 44,
          "color": "#1F2933"
        }
      ]
    },
    "back_cover": {
      "description": "CTA card floated above a warm background panel.",
      "background": {
        "type": "solid",
        "color": "#FBF7F1"
