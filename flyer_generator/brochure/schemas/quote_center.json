        { "type": "text", "bbox": [80, 260, 940, 380], "role": "section_heading", "content_key": "sections[0].heading", "section_index": 0, "color": "#1F2937", "font_size": 72, "line_height": 86, "italic": true, "z": 10 },
        { "type": "shape", "kind": "rect", "rect": [80, 680, 180, 3], "fill": { "type": "solid", "color": "#2F6E5B" }, "z": 6 },
        { "type": "text", "bbox": [80, 720, 940, 420], "role": "lead_paragraph", "content_key": "sections[0].lead_paragraph", "section_index": 0, "color": "#1F2937", "font_size": 32, "line_height": 48, "z": 10 },
        { "type": "bullets", "bbox": [80, 1200, 940, 900], "content_key": "sections[0].bullets", "section_index": 0, "max_items": 4, "max_chars_per_item": 52, "bullet_style": "dash", "font_size": 28, "line_height": 42, "text_color": "#1F2937", "bullet_color": "#2F6E5B", "item_spacing": 26, "z": 10 },
        { "type": "shape", "kind": "ellipse", "rect": [880, 2280, 200, 200], "fill": { "type": "solid", "color": "#2F6E5B" }, "opacity": 0.12, "bleed": "right", "z": 1 }
      ]
