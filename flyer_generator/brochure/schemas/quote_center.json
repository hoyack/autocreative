      "background": { "type": "solid", "color": "#FDFBF6" },
      "elements": [
        { "type": "shape", "kind": "rect", "rect": [0, 0, 1100, 6], "fill": { "type": "solid", "color": "#2F6E5B" }, "bleed": "top", "z": 0 },
        { "type": "text", "bbox": [80, 180, 940, 60], "role": "static", "static_text": "TWO", "font_size": 28, "letter_spacing": 8, "color": "#2F6E5B", "uppercase": true, "font_family": "'Source Serif Pro', Georgia, serif", "z": 10 },
        { "type": "text", "bbox": [80, 260, 940, 380], "role": "section_heading", "content_key": "sections[1].heading", "section_index": 1, "color": "#1F2937", "font_size": 72, "line_height": 86, "italic": true, "z": 10 },
        { "type": "shape", "kind": "rect", "rect": [80, 680, 180, 3], "fill": { "type": "solid", "color": "#2F6E5B" }, "z": 6 },
        { "type": "text", "bbox": [80, 720, 940, 420], "role": "lead_paragraph", "content_key": "sections[1].lead_paragraph", "section_index": 1, "color": "#1F2937", "font_size": 32, "line_height": 48, "z": 10 },
        { "type": "bullets", "bbox": [80, 1200, 940, 900], "content_key": "sections[1].bullets", "section_index": 1, "max_items": 4, "max_chars_per_item": 52, "bullet_style": "dash", "font_size": 28, "line_height": 42, "text_color": "#1F2937", "bullet_color": "#2F6E5B", "item_spacing": 26, "z": 10 },
        { "type": "shape", "kind": "circle", "rect": [-180, 2200, 380, 380], "fill": { "type": "solid", "color": "#2F6E5B" }, "opacity": 0.10, "bleed": "left", "z": 1 }
      ]
    },
    "inner_right": {
      "description": "Cream panel mirroring inner_left; accent ribbon on opposite side.",
      "background": { "type": "solid", "color": "#FDFBF6" },
      "elements": [
        { "type": "shape", "kind": "rect", "rect": [0, 0, 1100, 6], "fill": { "type": "solid", "color": "#2F6E5B" }, "bleed": "top", "z": 0 },
        { "type": "text", "bbox": [80, 180, 940, 60], "role": "static", "static_text": "THREE", "font_size": 28, "letter_spacing": 8, "color": "#2F6E5B", "uppercase": true, "font_family": "'Source Serif Pro', Georgia, serif", "z": 10 },
        { "type": "text", "bbox": [80, 260, 940, 380], "role": "section_heading", "content_key": "sections[2].heading", "section_index": 2, "color": "#1F2937", "font_size": 72, "line_height": 86, "italic": true, "z": 10 },
        { "type": "shape", "kind": "rect", "rect": [80, 680, 180, 3], "fill": { "type": "solid", "color": "#2F6E5B" }, "z": 6 },
        { "type": "text", "bbox": [80, 720, 940, 420], "role": "lead_paragraph", "content_key": "sections[2].lead_paragraph", "section_index": 2, "color": "#1F2937", "font_size": 32, "line_height": 48, "z": 10 },
        { "type": "bullets", "bbox": [80, 1200, 940, 900], "content_key": "sections[2].bullets", "section_index": 2, "max_items": 4, "max_chars_per_item": 52, "bullet_style": "dash", "font_size": 28, "line_height": 42, "text_color": "#1F2937", "bullet_color": "#2F6E5B", "item_spacing": 26, "z": 10 },
        { "type": "shape", "kind": "triangle", "rect": [880, 2280, 260, 260], "path_params": { "orient": "up" }, "fill": { "type": "solid", "color": "#2F6E5B" }, "opacity": 0.12, "bleed": "right", "z": 1 }
