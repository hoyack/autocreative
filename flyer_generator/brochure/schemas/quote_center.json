        { "type": "shape", "kind": "ellipse", "rect": [80, 280, 940, 1460], "fill": { "type": "linear_gradient", "stops": [{ "offset": 0.0, "color": "#2F6E5B", "opacity": 0.18 }, { "offset": 1.0, "color": "#FDFBF6", "opacity": 1.0 }], "angle": 135 }, "z": 2 },
        { "type": "text", "bbox": [160, 420, 780, 160], "role": "static", "static_text": "\u201C", "font_size": 280, "line_height": 280, "color": "#2F6E5B", "weight": "bold", "align": "left", "z": 10 },
        { "type": "text", "bbox": [120, 600, 860, 740], "role": "cover_title", "content_key": "title", "color": "#1F2937", "font_size": 86, "line_height": 108, "align": "center", "italic": true, "z": 10 },
        { "type": "shape", "kind": "rect", "rect": [470, 1420, 160, 4], "fill": { "type": "solid", "color": "#2F6E5B" }, "z": 8 },
        { "type": "text", "bbox": [120, 1450, 860, 180], "role": "cover_subtitle", "content_key": "subtitle", "font_size": 34, "align": "center", "color": "#4B5563", "z": 10 },
        { "type": "text", "bbox": [80, 2020, 940, 100], "role": "org_name", "content_key": "org", "align": "center", "font_size": 44, "uppercase": true, "letter_spacing": 8, "color": "#2F6E5B", "weight": "semibold", "z": 10 },
        { "type": "text", "bbox": [80, 2140, 940, 80], "role": "tagline", "content_key": "tagline", "align": "center", "font_size": 28, "italic": true, "color": "#6B7280", "z": 10 },
        { "type": "shape", "kind": "rect", "rect": [0, 2500, 1100, 50], "fill": { "type": "linear_gradient", "stops": [{ "offset": 0.0, "color": "#FDFBF6", "opacity": 0.0 }, { "offset": 1.0, "color": "#2F6E5B", "opacity": 0.22 }], "angle": 180 }, "bleed": "bottom", "z": 1 }
      ]
    },
    "back_cover": {
      "description": "Gradient green panel, quote-style CTA, minimal contact.",
      "background": { "type": "linear_gradient", "stops": [{ "offset": 0.0, "color": "#2F6E5B", "opacity": 1.0 }, { "offset": 1.0, "color": "#1D4A3C", "opacity": 1.0 }], "angle": 180 },
      "elements": [
        { "type": "shape", "kind": "rect", "rect": [0, 0, 1100, 2550], "fill": { "type": "linear_gradient", "stops": [{ "offset": 0.0, "color": "#2F6E5B", "opacity": 1.0 }, { "offset": 1.0, "color": "#1D4A3C", "opacity": 1.0 }], "angle": 180 }, "bleed": "all", "z": 0 },
