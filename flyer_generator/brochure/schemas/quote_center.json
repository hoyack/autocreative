{
  "schema_version": "1",
  "name": "quote_center",
  "description": "Whitespace-positive: one large pull-quote on front cover, gradient back panel, minimal inner panels with ribbon accents. Works for non-profits, mission-driven brands, hospitality.",
  "tone_keywords": ["calm", "mission-driven", "non-profit", "testimonial", "whitespace"],
  "canvas": { "width": 1100, "height": 2550 },
  "palette": {
    "accent_default": "#2F6E5B",
    "neutral_dark": "#1F2937",
    "neutral_light": "#FDFBF6",
    "muted": "#E8E3D8"
  },
  "typography": {
    "heading_family": "'Playfair Display', Georgia, serif",
    "body_family": "'Source Serif Pro', Georgia, serif",
    "cover_title_size": 112,
    "cover_subtitle_size": 38,
    "heading_size": 58,
    "body_size": 30,
    "body_line_height": 46,
    "body_max_chars_per_line": 32,
    "bullet_size": 30,
    "bullet_line_height": 42
  },
  "panels": {
    "front_cover": {
      "description": "Cream background. Huge oval pull quote shape centered. Title at top, org at bottom.",
      "background": { "type": "solid", "color": "#FDFBF6" },
