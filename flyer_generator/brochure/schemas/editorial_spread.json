{
  "schema_version": "1",
  "name": "editorial_spread",
  "description": "Magazine-inspired tri-fold using serif headlines, strong rhythm, and asymmetric editorial columns.",
  "tone_keywords": ["editorial", "cultural", "serif", "asymmetrical", "storytelling"],
  "canvas": {
    "width": 1100,
    "height": 2550
  },
  "palette": {
    "accent_default": "#B74B3D",
    "neutral_dark": "#1F1816",
    "neutral_light": "#F8F3EC",
    "muted": "#DDD3C9",
    "extras": {
      "paper_note": "#EDE3D8",
      "charcoal_soft": "#544640"
    }
  },
  "typography": {
    "heading_family": "'Playfair Display', 'Times New Roman', serif",
    "body_family": "'Source Serif Pro', 'Georgia', serif",
    "cover_title_size": 112,
    "cover_subtitle_size": 34,
    "heading_size": 52,
    "body_size": 34,
    "body_line_height": 44,
    "body_max_chars_per_line": 27,
    "bullet_size": 32,
    "bullet_line_height": 42
  },
  "panels": {
    "front_cover": {
      "description": "Typography-led cover with a narrow image strip and vertical rule.",
      "background": {
        "type": "solid",
        "color": "#F8F3EC"
      },
      "elements": [
        {
          "type": "divider",
          "orientation": "vertical",
          "position": [170, 160, 170, 2120],
          "thickness": 4.0,
          "color": "#B74B3D"
        },
        {
          "type": "image_placeholder",
          "bbox": [760, 220, 220, 1200],
          "slot": "hero",
          "mask": "rounded",
          "corner_radius": 10,
          "fallback_fill": {
            "type": "linear_gradient",
            "angle": 180,
            "stops": [
              { "offset": 0.0, "color": "#DDD3C9" },
              { "offset": 1.0, "color": "#F8F3EC" }
            ]
          },
          "z": 1
        },
        {
          "type": "text",
          "bbox": [230, 260, 460, 520],
          "role": "cover_title",
          "content_key": "title",
          "font_size": 112,
          "line_height": 98,
          "weight": "bold",
          "color": "#1F1816"
        },
        {
          "type": "text",
          "bbox": [240, 920, 420, 180],
          "role": "cover_subtitle",
          "content_key": "subtitle",
          "font_size": 34,
          "line_height": 42,
          "italic": true,
          "color": "#544640"
        },
        {
          "type": "text",
          "bbox": [240, 1180, 320, 60],
          "role": "org_name",
          "content_key": "org",
          "font_size": 22,
          "line_height": 28,
          "weight": "medium",
          "uppercase": true,
          "letter_spacing": 1.8,
          "color": "#B74B3D"
        }
      ]
    },
    "back_cover": {
      "description": "Elegant CTA block with fine rules and generous margins.",
      "background": {
        "type": "solid",
        "color": "#F8F3EC"
      },
      "elements": [
        {
          "type": "divider",
          "orientation": "horizontal",
          "position": [120, 210, 930, 210],
          "thickness": 2.0,
          "color": "#B74B3D"
        },
        {
          "type": "divider",
          "orientation": "horizontal",
          "position": [120, 1240, 930, 1240],
          "thickness": 2.0,
          "color": "#DDD3C9"
        },
        {
          "type": "text",
          "bbox": [120, 280, 700, 150],
          "role": "cta_heading",
          "content_key": "back_panel.heading",
          "font_size": 52,
          "line_height": 58,
          "weight": "bold",
          "color": "#1F1816"
        },
        {
          "type": "text",
          "bbox": [120, 500, 700, 340],
          "role": "cta_body",
          "content_key": "back_panel.body",
          "font_size": 30,
          "line_height": 44,
          "color": "#544640"
        },
        {
          "type": "text",
          "bbox": [120, 1320, 700, 60],
          "role": "contact_email",
          "content_key": "contact.email",
          "font_size": 24,
          "line_height": 30,
          "color": "#B74B3D"
        }
      ]
    },
    "tuck_flap": {
      "description": "Thin editorial flap with monogram and strapline.",
      "background": {
        "type": "solid",
        "color": "#EDE3D8"
      },
      "elements": [
        {
          "type": "logo_placeholder",
          "bbox": [120, 200, 180, 180],
          "fallback_style": "initials_plain",
          "fallback_color": "#B74B3D"
        },
        {
          "type": "text",
          "bbox": [120, 470, 640, 70],
          "role": "org_name",
          "content_key": "org",
          "font_size": 34,
          "line_height": 40,
          "weight": "bold",
          "color": "#1F1816"
        },
        {
          "type": "text",
          "bbox": [120, 580, 660, 170],
          "role": "tagline",
          "content_key": "tagline",
          "font_size": 24,
          "line_height": 34,
          "italic": true,
          "color": "#544640"
        }
      ]
    },
    "inner_left": {
      "description": "Long-form article panel with fine vertical rule and inset image.",
      "background": {
        "type": "solid",
        "color": "#F8F3EC"
      },
      "elements": [
        {
          "type": "divider",
          "orientation": "vertical",
          "position": [140, 180, 140, 1960],
          "thickness": 2.0,
          "color": "#DDD3C9"
        },
        {
          "type": "image_placeholder",
          "bbox": [190, 220, 620, 360],
          "slot": "spot_1",
          "mask": "rounded",
          "corner_radius": 10,
          "fallback_fill": {
            "type": "linear_gradient",
            "angle": 12,
            "stops": [
              { "offset": 0.0, "color": "#DDD3C9" },
              { "offset": 1.0, "color": "#F8F3EC" }
            ]
          },
          "z": 1
        },
        {
          "type": "text",
          "bbox": [190, 660, 640, 150],
          "role": "section_heading",
          "content_key": "sections[0].heading",
          "font_size": 52,
          "line_height": 58,
          "weight": "bold",
          "color": "#1F1816"
        },
        {
          "type": "text",
          "bbox": [190, 870, 640, 420],
          "role": "body",
          "content_key": "sections[0].lead_paragraph",
          "font_size": 30,
          "line_height": 44,
          "color": "#544640"
        }
      ]
    },
    "inner_center": {
      "description": "Editorial quote panel with asymmetry and a fine top rule.",
      "background": {
        "type": "solid",
        "color": "#F8F3EC"
      },
      "elements": [
        {
          "type": "divider",
          "orientation": "horizontal",
          "position": [120, 190, 940, 190],
          "thickness": 2.0,
          "color": "#B74B3D"
        },
        {
          "type": "text",
          "bbox": [120, 280, 740, 140],
          "role": "section_heading",
          "content_key": "sections[1].heading",
          "font_size": 48,
          "line_height": 54,
          "weight": "bold",
          "color": "#1F1816"
        },
        {
          "type": "text",
          "bbox": [220, 520, 560, 320],
          "role": "quote",
          "content_key": "sections[1].quote",
          "font_size": 40,
          "line_height": 52,
          "italic": true,
          "color": "#B74B3D"
        },
        {
          "type": "text",
          "bbox": [220, 880, 500, 60],
          "role": "static",
          "content_key": "sections[1].quote_attribution",
          "font_size": 20,
          "line_height": 26,
          "uppercase": true,
          "letter_spacing": 1.5,
          "color": "#544640"
        }
      ]
    },
    "inner_right": {
      "description": "Closing column with compact heading and short copy.",
      "background": {
        "type": "solid",
        "color": "#F8F3EC"
      },
      "elements": [
        {
          "type": "divider",
          "orientation": "vertical",
          "position": [880, 180, 880, 2100],
          "thickness": 2.0,
          "color": "#DDD3C9"
        },
        {
          "type": "text",
          "bbox": [120, 260, 620, 150],
          "role": "section_heading",
          "content_key": "sections[2].heading",
          "font_size": 50,
          "line_height": 56,
          "weight": "bold",
          "color": "#1F1816"
        },
        {
          "type": "text",
          "bbox": [120, 480, 620, 340],
          "role": "body",
          "content_key": "sections[2].lead_paragraph",
          "font_size": 30,
          "line_height": 44,
          "color": "#544640"
        }
      ]
    }
  }
}
