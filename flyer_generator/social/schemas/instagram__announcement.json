{
  "schema_version": "1",
  "name": "instagram__announcement",
  "platform": "instagram",
  "intent": "announcement",
  "description": "Instagram feed-square (1080x1080) announcement. Full-bleed hero with a centered scrim band carrying title and CTA; brand logo top-left. Palette + typography injected from the brand kit at render time.",
  "canvas": { "width": 1080, "height": 1080 },
  "palette": null,
  "typography": null,
  "text_budgets": {
    "copy.title": 80,
    "copy.body": 1500,
    "copy.cta": 40,
    "copy.hashtags": 250
  },
  "image_slot": {
    "bbox": [0, 0, 1080, 1080],
    "aspect": "1:1",
    "slot_name": "hero"
  },
  "shapes": [
    {
      "type": "shape",
      "kind": "rect",
      "rect": [0, 360, 1080, 360],
      "fill": { "type": "solid", "color": "#000000", "opacity": 0.55 },
      "z": 5
    }
  ],
  "text_slots": [
    {
      "bbox": [80, 420, 920, 200],
      "role": "title",
      "content_key": "copy.title",
      "max_chars": 80,
      "color_role": "neutral_light",
      "font_role": "heading",
      "font_size": 72,
      "font_weight": "bold",
      "align": "center",
      "valign": "top"
    },
    {
      "bbox": [80, 640, 920, 60],
      "role": "cta",
      "content_key": "copy.cta",
      "max_chars": 40,
      "color_role": "accent",
      "font_role": "body",
      "font_size": 28,
      "font_weight": "semibold",
      "align": "center",
      "valign": "top",
      "uppercase": true
    }
  ],
  "logo_slot": {
    "type": "logo_placeholder",
    "bbox": [40, 40, 140, 140],
    "align": "center",
    "valign": "middle",
    "fallback_style": "monogram_circle",
    "z": 20
  }
}
