{
  "schema_version": "1",
  "name": "classic_portrait",
  "description": "Serif headline over hero image; clean back with body + address block.",
  "tone_keywords": ["editorial", "serif", "understated"],
  "canvas": { "width": 1200, "height": 1800 },
  "palette": {
    "accent_default": "#1E3A5F",
    "neutral_dark": "#1A1A1A",
    "neutral_light": "#FAFAF7",
    "muted": "#E8E6E1",
    "scrim_opacity_top": 0.55,
    "scrim_opacity_bottom": 0.65
  },
  "typography": {
    "heading_family": "'Playfair Display', 'Times New Roman', serif",
    "body_family": "'Source Serif Pro', Georgia, serif",
    "cover_title_size": 96,
    "body_size": 32,
    "body_line_height": 42
  },
  "panels": {
    "front": {
      "description": "Full-bleed hero image with bottom-scrim gradient, serif title overlay, and body copy beneath.",
      "elements": [
        { "type": "image_placeholder", "bbox": [0, 0, 1200, 1800], "slot": "hero", "show_placeholder_label": false, "z": 0 },
        { "type": "shape", "kind": "rect", "rect": [0, 1300, 1200, 500], "fill": { "type": "linear_gradient", "stops": [{ "offset": 0, "color": "#000000", "opacity": 0.0 }, { "offset": 1, "color": "#000000", "opacity": 0.65 }], "angle": 0 }, "z": 3 },
        { "type": "text", "bbox": [80, 1340, 1040, 220], "role": "cover_title", "content_key": "headline", "color": "#FAFAF7", "valign": "top", "z": 10 },
        { "type": "text", "bbox": [80, 1580, 1040, 190], "role": "body", "content_key": "body", "color": "#FAFAF7", "valign": "top", "z": 11 },
        { "type": "shape", "kind": "rect", "rect": [0, 1788, 1200, 12], "fill": { "type": "solid", "color": "#1E3A5F" }, "z": 5 }
      ]
    },
    "back": {
      "description": "Typographic back: body left, vertical divider, address block bottom-right, stamp box top-right.",
      "background": { "type": "solid", "color": "#FAFAF7" },
      "elements": [
        { "type": "text", "bbox": [80, 80, 1040, 900], "role": "body", "content_key": "body", "color": "#1A1A1A", "z": 10 },
        { "type": "divider", "orientation": "vertical", "position": [600, 80, 600, 1720], "color": "#1A1A1A", "thickness": 1, "opacity": 0.35, "z": 5 },
        { "type": "text", "bbox": [680, 1080, 440, 60], "role": "contact_name", "content_key": "address_block.recipient_name", "color": "#1A1A1A", "weight": "semibold", "z": 10 },
        { "type": "text", "bbox": [680, 1150, 440, 60], "role": "contact_address", "content_key": "address_block.street", "color": "#1A1A1A", "z": 10 },
        { "type": "text", "bbox": [680, 1220, 440, 60], "role": "contact_address", "content_key": "address_block.city_state_zip", "color": "#1A1A1A", "z": 10 },
        { "type": "shape", "kind": "rect", "rect": [1000, 80, 140, 180], "fill": { "type": "solid", "color": "#FAFAF7", "opacity": 0.0 }, "stroke": { "color": "#1A1A1A", "width": 2, "opacity": 0.4, "dash": [8, 8] }, "z": 2 },
        { "type": "text", "bbox": [1000, 140, 140, 60], "role": "static", "static_text": "PLACE\nSTAMP", "font_size": 18, "align": "center", "color": "#1A1A1A", "opacity": 0.5, "z": 10 }
      ]
    }
  }
}
