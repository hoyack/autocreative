{
  "schema_version": "1",
  "name": "cinematic_onesheet",
  "description": "Heavy bottom block with accent stripes. Designed for 27x40 theatrical one-sheet reading distance.",
  "tone_keywords": ["cinematic", "dramatic", "theatrical"],
  "canvas": { "width": 5400, "height": 7200 },
  "palette": {
    "accent_default": "#C9A227",
    "neutral_dark": "#0F0F12",
    "neutral_light": "#F5F1E6",
    "muted": "#2A2A2E",
    "scrim_opacity_top": 0.40,
    "scrim_opacity_bottom": 0.95
  },
  "typography": {
    "heading_family": "'Bebas Neue', 'Impact', 'Helvetica Neue', sans-serif",
    "body_family": "'Helvetica Neue', Arial, sans-serif",
    "cover_title_size": 380,
    "cover_subtitle_size": 200,
    "heading_size": 240,
    "body_size": 120,
    "body_line_height": 160
  },
  "panels": {
    "hero": {
      "description": "Image fills upper 70% (oversize cover title overlaid). Bottom 30% is a solid dark block carrying subtitle + body in white-on-dark, framed by two thin accent stripes inset 50px from each edge.",
      "elements": [
        { "type": "image_placeholder", "bbox": [0, 0, 5400, 5040], "slot": "hero", "corner_radius": 0, "show_placeholder_label": true, "z": 0 },
        { "type": "shape", "kind": "rect", "rect": [0, 5040, 5400, 2160], "fill": { "type": "solid", "color": "#0F0F12" }, "z": 3 },
        { "type": "shape", "kind": "rect", "rect": [50, 5060, 5300, 12], "fill": { "type": "solid", "color": "#C9A227" }, "z": 6 },
        { "type": "shape", "kind": "rect", "rect": [50, 7128, 5300, 12], "fill": { "type": "solid", "color": "#C9A227" }, "z": 6 },
        { "type": "text", "bbox": [200, 600, 5000, 2200], "role": "cover_title", "content_key": "event.title", "color": "#F5F1E6", "align": "center", "valign": "middle", "uppercase": true, "weight": "bold", "letter_spacing": 8, "z": 10 },
        { "type": "text", "bbox": [200, 5260, 5000, 400], "role": "cover_subtitle", "content_key": "event.subheading", "color": "#F5F1E6", "align": "center", "valign": "top", "z": 10 },
        { "type": "text", "bbox": [200, 5760, 5000, 1000], "role": "body", "content_key": "event.body", "color": "#F5F1E6", "align": "center", "valign": "top", "z": 10 },
        { "type": "text", "bbox": [200, 6850, 5000, 220], "role": "cta_heading", "content_key": "event.cta_text", "color": "#C9A227", "align": "center", "uppercase": true, "letter_spacing": 16, "z": 10 }
      ]
    }
  }
}
