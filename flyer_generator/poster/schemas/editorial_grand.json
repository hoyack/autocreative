{
  "schema_version": "1",
  "name": "editorial_grand",
  "description": "Serif typography, narrow scrim, full-bleed hero. Tuned for 18x24 reading distance.",
  "tone_keywords": ["editorial", "serif", "spacious"],
  "canvas": { "width": 5400, "height": 7200 },
  "palette": {
    "accent_default": "#1E3A5F",
    "neutral_dark": "#1A1A1A",
    "neutral_light": "#FAFAF7",
    "muted": "#E8E6E1",
    "scrim_opacity_top": 0.55,
    "scrim_opacity_bottom": 0.65
  },
  "typography": {
    "heading_family": "'Playfair Display', 'Times New Roman', serif",
    "body_family": "'Source Serif Pro', Georgia, serif",
    "cover_title_size": 360,
    "cover_subtitle_size": 220,
    "heading_size": 260,
    "body_size": 140,
    "body_line_height": 180
  },
  "panels": {
    "hero": {
      "description": "Full-bleed hero with serif title upper-left, body block centered, accent rule at bottom.",
      "elements": [
        { "type": "image_placeholder", "bbox": [0, 0, 5400, 7200], "slot": "hero", "corner_radius": 0, "show_placeholder_label": true, "z": 0 },
        { "type": "shape", "kind": "rect", "rect": [0, 7160, 5400, 40], "fill": { "type": "solid", "color": "#1E3A5F" }, "z": 5 },
        { "type": "text", "bbox": [400, 500, 4600, 1800], "role": "cover_title", "content_key": "event.title", "color": "#FAFAF7", "valign": "top", "z": 10 },
        { "type": "text", "bbox": [400, 2400, 4600, 400], "role": "cover_subtitle", "content_key": "event.subheading", "color": "#FAFAF7", "valign": "top", "z": 10 },
        { "type": "text", "bbox": [400, 6900, 4600, 200], "role": "static", "static_text": "ESTABLISHED", "font_size": 80, "letter_spacing": 18, "uppercase": true, "color": "#FAFAF7", "z": 10 }
      ]
    }
  }
}
