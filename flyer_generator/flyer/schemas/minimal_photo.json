{
  "schema_version": "1",
  "name": "minimal_photo",
  "description": "Minimal sans title bottom-left, no top scrim, single accent dot. Photography-first.",
  "tone_keywords": ["minimal", "photographic", "clean"],
  "subtype_compat": ["event", "info"],
  "canvas": { "width": 1080, "height": 1920 },
  "palette": {
    "accent_default": "#FBBF24",
    "neutral_dark": "#1A1A1A",
    "neutral_light": "#FAFAFA",
    "muted": "#E5E5E5",
    "scrim_opacity_top": 0.0,
    "scrim_opacity_bottom": 0.35
  },
  "typography": {
    "heading_family": "'Inter', 'Helvetica Neue', sans-serif",
    "body_family": "'Inter', sans-serif",
    "cover_title_size": 68,
    "body_size": 30,
    "body_line_height": 40
  },
  "panels": {
    "hero": {
      "description": "Full-bleed hero photograph, title+details bottom-left, single accent dot.",
      "elements": [
        { "type": "image_placeholder", "bbox": [0, 0, 1080, 1920], "slot": "hero", "corner_radius": 0, "show_placeholder_label": true, "z": 0 },
        { "type": "shape", "kind": "circle", "rect": [60, 1750, 30, 30], "fill": { "type": "solid", "color": "#FBBF24" }, "z": 5 },
        { "type": "text", "bbox": [60, 1500, 960, 260], "role": "cover_title", "content_key": "event.title", "color": "#FAFAFA", "valign": "top", "z": 10 },
        { "type": "text", "bbox": [60, 1790, 960, 50], "role": "body", "content_key": "event.date", "color": "#FAFAFA", "z": 10 },
        { "type": "text", "bbox": [60, 1840, 960, 50], "role": "body", "content_key": "event.location_name", "color": "#FAFAFA", "z": 10 }
      ]
    }
  }
}
