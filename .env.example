# Required API keys
FLYER_ANTHROPIC_API_KEY=your-anthropic-api-key-here
FLYER_COMFYCLOUD_API_KEY=your-comfycloud-api-key-here

# Optional overrides (defaults shown)
FLYER_COMFYCLOUD_BASE_URL=https://cloud.comfy.org
FLYER_VISION_MODEL=claude-sonnet-4-5
FLYER_VISION_MAX_TOKENS=1024
FLYER_VISION_TIMEOUT_SECONDS=60
FLYER_MAX_BG_ATTEMPTS=3
FLYER_VISION_CONFIDENCE_THRESHOLD=0.6
FLYER_POLL_INITIAL_WAIT_SECONDS=3.0
FLYER_POLL_INTERVAL_SECONDS=4.0
FLYER_POLL_MAX_ATTEMPTS=20
FLYER_OUTPUT_DIR=./output
FLYER_LOG_LEVEL=INFO
FLYER_LOG_FORMAT=text
